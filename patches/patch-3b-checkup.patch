+// 기관별 뷰 — 기관별로 그룹핑, 대분류(CBC/UA/STD 등)별 정리
+function _renderCheckupByInstitution(checkups) {
+  if (!checkups.length) return '<div style="font-size:.72rem;color:var(--mu);text-align:center;padding:20px">검진 기록이 없습니다.</div>';
+  const byInst = {};
+  checkups.forEach(c => { const inst = c.institution || '기관 미입력'; if (!byInst[inst]) byInst[inst] = []; byInst[inst].push(c); });
+  return Object.entries(byInst).sort((a, b) => {
+    const latestA = a[1].reduce((m, c) => c.date > m ? c.date : m, '');
+    const latestB = b[1].reduce((m, c) => c.date > m ? c.date : m, '');
+    return latestB.localeCompare(latestA);
+  }).map(([inst, checks]) => {
+    const totalItems = checks.reduce((s, c) => s + (c.results?.length || 0), 0);
+    const dates = [...new Set(checks.map(c => c.date))].sort().reverse();
+    const majorCats = {};
+    checks.forEach(c => {
+      (c.results || []).forEach(r => {
+        const cat = r.category || 'other';
+        const catDef = _CHECKUP_CATEGORIES[cat] || _CHECKUP_CATEGORIES.other;
+        const major = catDef.major || 'other';
+        if (!majorCats[major]) majorCats[major] = { items: [], abnormal: 0 };
+        majorCats[major].items.push({ ...r, _date: c.date });
+        if (_isAbnormal(r.status)) majorCats[major].abnormal++;
+      });
+    });
+    const majorRows = _CHECKUP_MAJOR_CATEGORIES.filter(mc => majorCats[mc.key]).map(mc => {
+      const data = majorCats[mc.key];
+      const uniqueTests = [...new Set(data.items.map(r => r.stdCode || r.displayName))];
+      const abnormalNames = data.items.filter(r => _isAbnormal(r.status)).map(r => r.displayName);
+      const uniqueAbnormal = [...new Set(abnormalNames)];
+      const testByDate = {};
+      data.items.forEach(r => {
+        const key = r.stdCode || r.displayName;
+        if (!testByDate[key]) testByDate[key] = { name: r.displayName, unit: r.unit, entries: {} };
+        testByDate[key].entries[r._date] = { value: r.value, status: r.status };
+      });
+      const testRows = Object.entries(testByDate).map(([, td]) => {
+        const latestDate = Object.keys(td.entries).sort().reverse()[0];
+        const latest = td.entries[latestDate];
+        const statusColor = _statusColor(latest.status);
+        const statusIcon = _statusIcon(latest.status);
+        const history = Object.entries(td.entries).sort((a, b) => a[0].localeCompare(b[0])).map(([d, e]) =>
+          `<span style="font-size:.55rem;color:${_statusColor(e.status)};font-family:var(--mono)">${d.slice(5)}:${e.value}</span>`
+        ).join(' ');
+        return `<div style="display:flex;align-items:center;gap:4px;padding:2px 0;font-size:.68rem;border-bottom:1px solid var(--sf)">
+          <span style="color:${statusColor};min-width:12px;font-size:.6rem">${statusIcon}</span>
+          <span style="flex:1">${esc(td.name)}</span>
+          <span style="font-weight:600;color:${statusColor};font-family:var(--mono);min-width:40px;text-align:right">${esc(String(latest.value))}</span>
+          <span style="color:var(--mu);min-width:35px;font-size:.6rem">${esc(td.unit || '')}</span>
+        </div>
+        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:2px">${history}</div>`;
+      }).join('');
+      return `<div style="margin-bottom:8px">
+        <div style="display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:1.5px solid var(--bd);cursor:pointer" onclick="const d=this.nextElementSibling;d.style.display=d.style.display==='none'?'block':'none';this.querySelector('._inst-arrow').textContent=d.style.display==='none'?'▸':'▾'">
+          <span class="_inst-arrow" style="font-size:.6rem;color:var(--mu2)">▸</span>
+          <span style="font-size:.75rem;font-weight:600">${mc.name}</span>
+          <span style="font-size:.62rem;color:var(--mu)">${uniqueTests.length}항목</span>
+          ${data.abnormal > 0 ? `<span style="font-size:.6rem;color:#dc2626;font-weight:600">⚠ 이상 ${uniqueAbnormal.length}</span>` : '<span style="font-size:.6rem;color:#10b981">✅</span>'}
+        </div>
+        <div style="display:none;padding:4px 0 4px 8px">${testRows}</div>
+      </div>`;
+    }).join('');
+    return `<div style="padding:10px;background:var(--sf2);border:1.5px solid var(--bd);border-radius:8px;margin-bottom:6px">
+      <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
+        <span style="font-size:.85rem;font-weight:700;color:var(--ac)">🏥 ${esc(inst)}</span>
+        <span style="font-size:.62rem;color:var(--mu)">${checks.length}건 · ${totalItems}항목</span>
+        <span style="font-size:.58rem;color:var(--mu2);margin-left:auto">${dates.slice(0, 3).map(d => d.slice(5)).join(', ')}</span>
+      </div>
+      ${majorRows}
+    </div>`;
+  }).join('');
+}
