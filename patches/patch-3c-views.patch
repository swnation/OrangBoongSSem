+      <span style="font-family:var(--mono);font-weight:600;min-width:60px;text-align:right">$${d.cost.toFixed(4)}</span>
+    </div>`;
+  }).join('');
+  const recentCalls=[...allCalls].sort((a,b)=>(b.date+' '+(b.time||'')).localeCompare(a.date+' '+(a.time||''))).slice(0,20);
